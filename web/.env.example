# Copy to .env.local and fill in.

# Postgres (Prisma) + Redis (BullMQ)
DATABASE_URL="postgresql://jobops:jobops@localhost:5432/jobops?schema=public"
REDIS_URL="redis://localhost:6379"

# --- Supabase Auth (login/signup, incl. Google/GitHub/LinkedIn) ---
# From your Supabase project → Settings → API.
# Leave BLANK to disable auth entirely (dashboard stays open in local/dev).
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
