# career-ops — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# ── Gemini Integration (Issue #344) ─────────────────────────────────────────
# Required for: node gemini-eval.mjs "JD text here"
# Free API key: https://aistudio.google.com/apikey
# Free tier: 15 RPM / 1M tokens/day with gemini-2.5-flash (no billing needed)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Override default Gemini model ───────────────────────────────────
# Default: gemini-2.5-flash (free-tier, fast)
# Alternatives: gemini-1.5-flash, gemini-1.5-pro, gemini-2.5-flash-thinking-exp
# GEMINI_MODEL=gemini-2.5-flash

# ── NVIDIA NIM — multi-provider AI engine (lib-ai/, config/ai.yml) ────────────
# ONE key unlocks every model in config/ai.yml: DeepSeek V4 Pro, Kimi K2.6,
# GLM 5.1, MiniMax M3 — all OpenAI-compatible, free tier (~40 RPM).
# Get a key: https://build.nvidia.com  →  "Get API Key"
# Verify your model slugs resolve:  node ai.mjs verify
# Add more keys (separate NVIDIA accounts) for automatic rotation + 429 failover:
# calls round-robin across NVIDIA_NIM_API_KEY, _2, _3, ... to dodge rate limits.
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here
# NVIDIA_NIM_API_KEY_2=
# NVIDIA_NIM_API_KEY_3=

# ── freemodel.dev — free OpenAI-compatible GPT-5.x for lib-ai/config/ai.yml ────
# Models: gpt-5.5 (flagship), gpt-5.4, gpt-5.4-mini (fast/cheap), gpt-5.3-codex.
# Get a key: https://freemodel.dev  →  sign up (no card; $300 free credits).
# Verify slugs resolve:  node ai.mjs verify
FREE_MODEL_API_KEY=fe_oa_your_freemodel_key_here

# ── AgentRouter — GLM 5.2 reasoning relay (USED by config/ai.yml: evaluate_job) ─
# Its WAF blocks non-CLI clients, so config/ai.yml ships a CLI wire-image
# User-Agent under the provider's `headers:`. Models: glm-5.2, claude-opus-*,
# claude-haiku-*, deepseek-*. Note: tight TPM cap → it has gpt-5.5/NIM fallbacks.
AGENT_ROUTER_API_KEY=sk-your_agentrouter_key_here

# ── Aerolink — Claude Opus 4.8 etc. NOT usable by config/ai.yml (it TLS/client- ─
#    fingerprints; only the real Claude Code binary gets through). Use it as your
#    INTERACTIVE Claude Code model instead:
#      export ANTHROPIC_BASE_URL=https://capi.aerolink.lat
#      export ANTHROPIC_AUTH_TOKEN=$AEROLINK_API_KEY
# AEROLINK_API_KEY=aero_live_your_key_here

# ── Cold-outreach: email finders + verifiers (multiple keys per provider =
#    automatic failover: tries _1, then _2, ...). All have free tiers. ──────────
HUNTER_IO_API_KEY=           # finder + domain pattern + verifier (50 search/100 verify)
PROSPEO_API_KEY_1=           # finder (POST /enrich-person), 100 credits/key
PROSPEO_API_KEY_2=
SNOV_API_USER_ID=            # finder + verifier (OAuth: id + secret), async
SNOV_API_USER_SECRET=
BOUNCER_API_KEY_1=           # verifier — main deep verifier (100 credits/key)
BOUNCER_API_KEY_2=
ZERO_BOUNCE_API_KEY=         # verifier — tiny free tier (5); used last, when inconclusive

# ── Other providers (optional — also uncomment in config/ai.yml) ──────────────
# OPENROUTER_API_KEY=your_openrouter_key_here  # one key, hundreds of models
# ANTHROPIC_API_KEY=your_anthropic_key_here     # For Claude-based workflows
# OPENAI_API_KEY=your_openai_key_here           # Native OpenAI

# Adzuna free job API — get keys at https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── Apify — off-account LinkedIn people lookup (referral "Find real people") ───
# Powers the web dashboard's "Find real people" button: finds real public
# profiles via a no-login Apify actor (your LinkedIn is never used). Pay-per-use
# (~$0.001/result). Token: Apify console → Settings → API & Integrations.
# Add more tokens (from other Apify accounts) for automatic failover: the lookup
# tries APIFY_TOKEN first, then _2, _3, ... only if the previous one fails.
APIFY_TOKEN=
APIFY_TOKEN_2=
APIFY_TOKEN_3=

# ── Cold outreach: direct Gmail send (Nodemailer SMTP) ───────────────────────
# Enables the "Send now" button in the Outreach tab — sends cold emails
# directly from the dashboard without going through Gmail drafts.
#
# Step 1: GMAIL_USER — your Gmail address (the "From" address)
# Step 2: GMAIL_APP_PASSWORD — a 16-char App Password (NOT your Gmail password)
#   How to get one:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to: myaccount.google.com → Security → App passwords
#   3. Create an app password named "career-ops"
#   4. Paste the 16-char code below (spaces are optional)
GMAIL_USER=
GMAIL_APP_PASSWORD=
